POLL_INTERVAL_SECONDS=12
REQUEST_TIMEOUT_SECONDS=10
WATCHLIST_LIMIT=200
MIN_PICK_SCORE=75
MIN_PICK_RISK_REWARD=1.5
MAX_TOP10_HOLDER_PCT=35
REBOUND_MIN_MCAP_USD=200000
REBOUND_MAX_MCAP_USD=3000000
REBOUND_MIN_DRAWDOWN_PCT=35
REBOUND_MAX_DRAWDOWN_PCT=70
REBOUND_MIN_VOLUME_RECOVERY_RATIO=1.2
REBOUND_CONFIRM_CYCLES=2

# Helius Mainnet RPC (also can use secrets/local.env)
HELIUS_RPC_URL=

# DexScreener public API (no key; rate limit ~60/min)
DEXSCREENER_BASE=https://api.dexscreener.com
DEXSCREENER_CHUNK_SIZE=8

RUGCHECK_BASE=https://api.rugcheck.xyz
SOLSCAN_BASE=https://public-api.solscan.io
BIRDEYE_BASE=https://public-api.birdeye.so
BIRDEYE_API_KEY=
