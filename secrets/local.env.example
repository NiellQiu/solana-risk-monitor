# Copy this file to local.env and fill in values.
# local.env is gitignored.

# Helius — Mainnet RPC (from Helius dashboard → RPC)
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE

# Optional — Birdeye (only if you use it; otherwise DexScreener is used for discovery)
# BIRDEYE_API_KEY=

# Optional — DexScreener (defaults are fine)
# DEXSCREENER_BASE=https://api.dexscreener.com
# DEXSCREENER_CHUNK_SIZE=8

# Optional — Telegram alerts
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
