# Copy this file to local.env and fill in values.
# local.env is gitignored.

# Helius — Mainnet RPC (from Helius dashboard → RPC)
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE

# Optional — Birdeye (token list / market fields)
# BIRDEYE_API_KEY=

# Optional — Telegram alerts
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
